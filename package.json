{
  "name": "ray",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push:test": "cross-env DATABASE_URL=file:./test.db RUST_LOG=debug prisma db push --force-reset --skip-generate",
    "prisma:push:e2e": "cross-env DATABASE_URL=file:./e2e.db RUST_LOG=debug prisma db push --force-reset --skip-generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "npm run prisma:push:test && cross-env DATABASE_URL=file:./test.db vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:serve": "npm run prisma:push:e2e && cross-env NODE_ENV=production DATABASE_URL=file:./e2e.db PORT=3100 HOSTNAME=127.0.0.1 tsx server.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/material": "^7.3.2",
    "@prisma/client": "^6.17.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.65.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.17.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
